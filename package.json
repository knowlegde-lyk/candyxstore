{
  "name": "candyxoptimizer",
  "private": true,
  "version": "1.0.7",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "vite-dev": "vite",
    "dev": "concurrently \"npm run vite-dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dist": "vite build && electron-builder",
    "dist:protected": "set PROTECTED=1 && vite build && node scripts/build-protected.cjs",
    "dist:fuses": "node scripts/apply-fuses.cjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/knowlegde-lyk/candyxstore.git"
  },
  "build": {
    "appId": "com.candy.optimizer",
    "productName": "CANDYXOPTIMIZER",
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName} Portable.${ext}"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.cjs"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.575.0",
    "postprocessing": "^6.39.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.0",
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "javascript-obfuscator": "^5.3.0",
    "vite": "^7.3.1",
    "vite-plugin-obfuscator": "^1.0.5",
    "wait-on": "^9.0.4"
  }
}
